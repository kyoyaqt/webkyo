{
  "buildCommand": "",
  "outputDirectory": ".",
  "public": ".",
  "routes": [
    {
      "src": "^/Menu\\.html(?:\\?.*)?$",
      "dest": "/Menu.html",
      "methods": ["GET", "HEAD"]
    },
    {
      "src": "^/kasir\\.html(?:\\?.*)?$",
      "dest": "/kasir.html",
      "methods": ["GET", "HEAD"]
    },
    {
      "src": "^/admin\\.html(?:\\?.*)?$",
      "dest": "/admin.html",
      "methods": ["GET", "HEAD"]
    },
    {
      "src": "/(.*)$",
      "dest": "/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
